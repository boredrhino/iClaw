# LLM Provider (groq, openai, etc.)
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_key_here
# OPENAI_API_KEY=sk-...

# Appium/iOS Settings
APPIUM_SERVER=http://localhost:4723
DEVICE_UDID=your_iphone_udid_here
IOS_PLATFORM_VERSION=17.0  # Match your iOS version

# Agent Settings
MAX_STEPS=30
STEP_DELAY_MS=1500
