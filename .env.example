# LLM (pick one provider)
LLM_PROVIDER=groq          # or openai
GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...

# iOS / Appium
APPIUM_SERVER=http://localhost:4723
DEVICE_UDID=00008030-00123456789ABCDE              # your iPhone UDID
IOS_PLATFORM_VERSION=18.2                          # your iOS version, e.g. 17.0 or 18.2

# Agent behavior
MAX_STEPS=30
STEP_DELAY_MS=2000                                 # pause between steps in ms
